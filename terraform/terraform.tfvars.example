# Copiar este archivo a terraform.tfvars y rellenar con valores reales.
# terraform.tfvars está en .gitignore — NUNCA commitear.

subscription_id     = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
tenant_id           = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
location            = "eastus"
resource_group_name = "circleguard-rg"
cluster_name        = "circleguard-aks"
acr_name            = "circleguardacr"   # debe ser globalmente único en Azure
node_count          = 2
node_vm_size        = "Standard_B2ms"    # 2 vCPUs, 8 GB — reducir a B2s si faltan créditos
